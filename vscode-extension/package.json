{
  "name": "buddyparallel-vscode",
  "displayName": "BuddyParallel for VS Code",
  "description": "Local VS Code approval bridge for BuddyParallel hardware prompts.",
  "version": "0.0.1",
  "publisher": "by-xin",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:buddyparallel.chat",
    "onCommand:buddyParallel.requestBoardApproval",
    "onCommand:buddyParallel.insertApprovedComment",
    "onCommand:buddyParallel.sendTestNotice",
    "onCommand:buddyParallel.openCodexSidebar",
    "onCommand:buddyParallel.newCodexTask",
    "onCommand:buddyParallel.showCodexMonitorStatus",
    "onCommand:buddyParallel.showLogs"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "buddyParallel.requestBoardApproval",
        "title": "BuddyParallel: Request Board Approval",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.insertApprovedComment",
        "title": "BuddyParallel: Insert Approved Comment",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.sendTestNotice",
        "title": "BuddyParallel: Send Test Notice",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.openCodexSidebar",
        "title": "BuddyParallel: Open Codex Sidebar",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.newCodexTask",
        "title": "BuddyParallel: New Codex Task",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.showCodexMonitorStatus",
        "title": "BuddyParallel: Show Codex Monitor Status",
        "category": "BuddyParallel"
      },
      {
        "command": "buddyParallel.showLogs",
        "title": "BuddyParallel: Show Logs",
        "category": "BuddyParallel"
      }
    ],
    "chatParticipants": [
      {
        "id": "buddyparallel.chat",
        "name": "buddy",
        "fullName": "BuddyParallel",
        "description": "Hardware approval bridge and Codex monitor for VS Code",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show BuddyParallel and Codex monitor status"
          },
          {
            "name": "codex",
            "description": "Show Codex bridge actions"
          },
          {
            "name": "board",
            "description": "Run a BuddyParallel board approval test"
          }
        ]
      }
    ],
    "configuration": {
      "title": "BuddyParallel",
      "properties": {
        "buddyParallel.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:43112",
          "description": "Local BuddyParallel companion API base URL."
        },
        "buddyParallel.sessionTitle": {
          "type": "string",
          "default": "VS Code",
          "description": "Session title sent to the BuddyParallel companion."
        },
        "buddyParallel.requestTimeoutSeconds": {
          "type": "number",
          "default": 590,
          "minimum": 1,
          "description": "How long the extension waits for a hardware approval decision."
        },
        "buddyParallel.codexMonitoringEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Mirror stable Codex presence signals from VS Code to BuddyParallel."
        },
        "buddyParallel.codexPollingIntervalSeconds": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "How often BuddyParallel samples Codex task presence."
        },
        "buddyParallel.codexSessionTitle": {
          "type": "string",
          "default": "Codex",
          "description": "Session title sent to BuddyParallel for Codex presence updates."
        }
      }
    }
  }
}
